rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Администратор программы: coaches/{uid}.role == "admin" (или isAdmin: true).
    // Первого админа назначают вручную в Firebase Console → coaches → документ → поле role: "admin".
    function coachDoc() {
      return get(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }

    function isProgramAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/coaches/$(request.auth.uid))
        && (
          coachDoc().data.role == 'admin'
          || coachDoc().data.isAdmin == true
        );
    }

    function coachCanAccessStudent() {
      return request.auth != null && (
        isProgramAdmin() ||
        resource.data.coachId == request.auth.uid ||
        (resource.data.coach_ids is list && request.auth.uid in resource.data.coach_ids) ||
        (resource.data.coachIds is list && request.auth.uid in resource.data.coachIds)
      );
    }

    function isStudentPortalUser() {
      return request.auth != null
        && resource.data.portalAuthUid == request.auth.uid;
    }

    function studentPortalBindOk() {
      return request.auth != null
        && (!('portalAuthUid' in resource.data) || resource.data.portalAuthUid == null)
        && request.resource.data.portalAuthUid == request.auth.uid;
    }

    // Повторный вход с тем же PIN (новый анонимный uid после выхода / очистки данных браузера).
    function studentPortalLoginRebind() {
      return request.auth != null
        && resource.data.portalEnabled == true
        && 'portalAuthUid' in resource.data
        && resource.data.portalAuthUid != null
        && resource.data.portalAuthUid != request.auth.uid
        && request.resource.data.portalAuthUid == request.auth.uid
        && studentPortalLoginFieldsOnly();
    }

    function studentPortalLoginFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'portalAuthUid', 'portalEnabled', 'portalConsentAt', 'portalConsentVersion',
        'portalLastLoginAt', 'updatedAt', 'lastUpdatedSection', 'lastUpdatedAt',
      ]);
    }

    function studentPortalProgressOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'portalKnowledgeData', 'portalLastActivityAt', 'updatedAt', 'lastUpdatedSection', 'lastUpdatedAt',
      ]);
    }

    function studentPortalOnboardingOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'portalTrainingGoal', 'portalOnboardingCompletedAt', 'portalLastActivityAt',
        'updatedAt', 'lastUpdatedSection', 'lastUpdatedAt',
      ]);
    }

    /** Тренер добавляет себя в coach_ids по коду (ещё без read карточки). */
    function coachJoinStudentByCodeOk() {
      return request.auth != null
        && resource.data.short_id != null
        && request.auth.uid in request.resource.data.coach_ids
        && (
          !('coach_ids' in resource.data)
          || resource.data.coach_ids == null
          || !(request.auth.uid in resource.data.coach_ids)
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'coach_ids', 'updatedAt', 'lastUpdatedSection', 'lastUpdatedAt',
        ]);
    }

    match /students/{studentId} {
      // Отдельные allow read — Firestore сопоставляет их с where(coachId) и array-contains(coach_ids/coachIds).
      allow read: if request.auth != null && isProgramAdmin();
      allow read: if request.auth != null && resource.data.coachId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.coach_ids is list
        && request.auth.uid in resource.data.coach_ids;
      allow read: if request.auth != null
        && resource.data.coachIds is list
        && request.auth.uid in resource.data.coachIds;
      allow read: if request.auth != null
        && resource.data.portalAuthUid == request.auth.uid;
      // coachId (новое приложение), coach_ids (массив), coachIds (legacy script.js) — создатель должен быть в списке или совпадать с coachId
      allow create: if request.auth != null && (
        request.resource.data.coachId == request.auth.uid ||
        (request.resource.data.coach_ids is list && request.auth.uid in request.resource.data.coach_ids) ||
        (request.resource.data.coachIds is list && request.auth.uid in request.resource.data.coachIds)
      );
      allow update: if request.auth != null && (
        coachCanAccessStudent()
        || coachJoinStudentByCodeOk()
        || (isStudentPortalUser() && (studentPortalProgressOnly() || studentPortalOnboardingOnly() || studentPortalLoginFieldsOnly()))
        || (studentPortalBindOk() && studentPortalLoginFieldsOnly())
        || studentPortalLoginRebind()
      );
      allow delete: if request.auth != null && (
        isProgramAdmin() ||
        resource.data.coachId == request.auth.uid ||
        (resource.data.coach_ids is list && request.auth.uid in resource.data.coach_ids) ||
        (resource.data.coachIds is list && request.auth.uid in resource.data.coachIds)
      );
    }

    match /student_codes/{code} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null
        && code.matches('^[0-9]{6}$')
        && request.resource.data.studentId is string
        && request.resource.data.coachId == request.auth.uid;
      allow update, delete: if false;
    }

    match /coaches/{coachId} {
      allow read: if request.auth != null && (
        request.auth.uid == coachId || isProgramAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == coachId;
      // Тренер не может сам выдать себе role / isAdmin через приложение.
      allow update: if request.auth != null
        && request.auth.uid == coachId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin']);
      allow delete: if false;
    }

    match /accessCodes/{codeId} {
      allow read, write: if request.auth != null;
    }

    // Публичная страница прогресса /share/:token — только обезличенный payload (без ID ученика в URL).
    // ВАЖНО: после правок опубликуйте файл в Firebase Console → Firestore → Rules → «Опубликовать»,
    // иначе клиент получит Missing or insufficient permissions.
    // Банк упражнений для страниц «База качеств» (общий каталог клуба).
    match /motor_quality_exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // Каталог технических элементов программы (GIF / WebM / embed). Пишет только администратор.
    match /technical_program_atoms/{atomId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isProgramAdmin();
    }

    // Справочник нормативов (физика / функционал). Читает любой тренер; публикует администратор.
    match /legacy_norms/{normId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isProgramAdmin();
    }

    match /public_student_shares/{token} {
      // Чтение одного документа по точному токену (как в приложении). Список всей коллекции запрещён.
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /public_leaderboard_shares/{token} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    function isCoachEventOwner() {
      return request.auth != null && resource.data.coachId == request.auth.uid;
    }

    function isCoachEventCreate() {
      return request.auth != null && request.resource.data.coachId == request.auth.uid;
    }

    // Общий календарь тренера: coachId в документе = uid тренера (запрос: where coachId == uid).
    match /coach_events/{eventId} {
      allow read: if isProgramAdmin() || isCoachEventOwner();
      allow create: if isCoachEventCreate();
      allow update, delete: if isProgramAdmin() || isCoachEventOwner();
    }

    // Участники ориентиров Минспорта (календарь федерации, не редактируется).
    // Вход ученика: код (short_id) → PIN-hash. Чтение без авторизации (только get по id кода).
    match /student_portal_auth/{shortId} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if request.auth != null;
    }

    match /orientir_participation/{docId} {
      allow read: if request.auth != null
        && resource.data.coachId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.coachId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.coachId == request.auth.uid;
    }
  }
}
