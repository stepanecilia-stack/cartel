# Скопируйте в .env.local (локально) или задайте те же имена в Vercel → Settings → Environment Variables.
# Значения: Firebase Console → шестерёнка → «Настройки проекта» → «Ваши приложения» → веб-приложение.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
