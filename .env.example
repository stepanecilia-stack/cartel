# Скопируйте в .env.local (локально) или задайте те же имена в Vercel → Settings → Environment Variables.
# Значения: Firebase Console → шестерёнка → «Настройки проекта» → «Ваши приложения» → веб-приложение.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Виртуальные тренеры (Gemini через Cloud Function portalPersonaChat)
# 1) В GCP включите Vertex AI API для проекта cartel-academy
# 2) npm run deploy:functions
# 3) Firebase Auth → Authorized domains → ваш домен на Vercel (cartel-umber.vercel.app)
# VITE_FIREBASE_FUNCTIONS_REGION=europe-west1
# AI вкл. автоматически, если задан VITE_FIREBASE_* (локально и на Vercel)
# VITE_PORTAL_PERSONA_AI=0  — принудительно только скрипты

# Telegram @CartelCoachBot — webhook Cloud Function
VITE_TELEGRAM_WEBHOOK_URL=https://europe-west1-cartel-academy.cloudfunctions.net/telegramCoachWebhook
